rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPER FUNCTIONS ---
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    // Users & User-Specific Data
    match /users/{userId} {
      // Profile data: Tier, subscription status, scan counts
      allow read, write: if isAuthenticated() && isOwner(userId);

      // Inventory Module: All sourced books
      match /inventory/{bookId} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }

      // TaxVision Ledger: COGS and Expenses
      match /ledger/{expenseId} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }

      // SetVision: Series and set progress
      match /sets/{setId} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }
    }

    // SupportVision: Tickets
    // Users create their own, backend (Admin) updates them.
    match /Tickets/{ticketId} {
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      // Allow user to update their own ticket message if needed, but not the 'status' or 'response'
      allow update: if isAuthenticated() && resource.data.user_id == request.auth.uid 
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'response']);
      allow delete: if false; 
    }

    // Global AI Resources (Backend Managed)
    
    // MetadataCache: Shared data to reduce Gemini API costs
    match /MetadataCache/{cacheId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only written via Admin SDK in backend
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
